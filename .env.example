# Elasticsearch Configuration
# Copy this file to .env and fill in your values

# Elasticsearch cluster URL
ELASTICSEARCH_URL=http://localhost:9200

# Elasticsearch API Key
# Format 1: id:api_key (will be automatically base64 encoded)
# ELASTICSEARCH_API_KEY=your-api-key-id:your-api-key-secret

# Format 2: Base64 encoded API key
# ELASTICSEARCH_API_KEY=eW91ci1iYXNlNjQtZW5jb2RlZC1hcGkta2V5

# Format 3: Already formatted with ApiKey prefix
# ELASTICSEARCH_API_KEY=ApiKey eW91ci1iYXNlNjQtZW5jb2RlZC1hcGkta2V5

# Example for Elastic Cloud
# ELASTICSEARCH_URL=https://my-cluster.es.io:9243
# ELASTICSEARCH_API_KEY=my-api-key-id:my-api-key-secret
